# Single source of truth for geodb connectivity scripts — consumed by both the Bash
# scripts in geodb/shell/ and the Python package in geodb/python/.
#
# Fixes docs/architecture-review.md's duplication matrix: the RDS hostname alone was
# previously hardcoded independently across 7 files in 4 languages. Changing an
# environment fact now means editing exactly one line, here.
#
# This file contains no secrets: an AWS account ID, region, ARNs, and hostnames are
# infrastructure identifiers, not credentials. The one real secret this toolkit ever
# had (a hardcoded local DB password in start-ssm-tunnel-user.sh) has been removed —
# see docs/technical-debt-assessment.md Phase 0.
#
# Local per-developer overrides: create a gitignored geodb/config/environment.local.env
# and source it after this file to override any value below without editing this one.

AWS_ACCOUNT_ID=673586358783
AWS_REGION=eu-north-1

# --- RDS instance ---
GEODB_RDS_HOST=geodb-rds-pg.cnckeywiw239.eu-north-1.rds.amazonaws.com
GEODB_RDS_PORT=5432
GEODB_DB_NAME=geodb
GEODB_RDS_RESOURCE_ID=db-4FMMU67ZF6NDN77CMETXGADWZM

# --- Bastion (SSM port-forwarding target) ---
GEODB_BASTION_ID=i-022a8e8c2d2b0cf30
GEODB_BASTION_NAME=osw02605

# --- Local SSM tunnel port ---
GEODB_LOCAL_PORT=55432

# --- IAM roles per DB user (see docs/infrastructure-reference.md for the full policy) ---
GEODB_SUPERUSER_ROLE_ARN=arn:aws:iam::673586358783:role/rds/geodb-rds-pg-superuser-role
# TODO: not present anywhere in repo history yet — fill in once available.
GEODB_DBA_ROLE_ARN=
GEODB_READER_ROLE_ARN=

# --- AWS SSO (see geodb/QUICK_START.md for the one-time `aws configure sso` walkthrough) ---
AWS_SSO_PROFILE=geotech-dev
AWS_SSO_SESSION_NAME=geotech-dev
AWS_SSO_START_URL=https://identitycenter.amazonaws.com/ssoins-650839925b8e293c
AWS_SSO_PERMISSION_SET=WorkloadPowerUserAccess

